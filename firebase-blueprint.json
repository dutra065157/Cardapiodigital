{
  "entities": {
    "weeklyMenuDay": {
      "title": "Weekly Menu Day",
      "description": "Menu for a specific day of the week",
      "type": "object",
      "properties": {
        "dishes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "image": { "type": "string" },
              "price": { "type": "number" }
            },
            "required": ["name", "price"]
          }
        },
        "guarnicoes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["dishes", "guarnicoes"]
    },
    "order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "total": { "type": "number" },
        "status": { 
          "type": "string",
          "enum": ["Pendente", "Em preparo", "Entregue", "Cancelado"]
        },
        "createdAt": { "type": "number" },
        "items": {
          "type": "array"
        }
      },
      "required": ["customerName", "address", "total", "status", "createdAt", "items"]
    }
  },
  "firestore": {
    "/menu": {
      "schema": "weeklyMenuDay",
      "description": "Collection of daily menus where document ID is the day of the week"
    },
    "/orders": {
      "schema": "order",
      "description": "Collection of customer orders"
    }
  }
}
